{
  "$schema": "Striker 配置模板 — 复制为 config.json 后按需修改。环境变量 STRIKER_* 可覆盖任意字段",
  "serial_port": "/dev/serial0",
  "serial_baud": 921600,
  "transport": "serial",
  "mavlink_url": "",
  "battery_min_v": 11.1,
  "stall_speed_mps": 10.0,
  "heartbeat_timeout_s": 3.0,
  "safety_check_interval_s": 1.0,
  "field": "sitl_default",
  "dry_run": false,
  "release_method": "mavlink",
  "release_channel": 6,
  "release_pwm_open": 2000,
  "release_pwm_close": 1000,
  "release_gpio_pin": 17,
  "release_gpio_active_high": true,
  "vision_receiver_type": "tcp",
  "vision_host": "0.0.0.0",
  "vision_port": 9876,
  "recorder_output_path": "flight_log.csv",
  "recorder_sample_rate_hz": 1.0,
  "log_level": "INFO"
}
