# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
dist/
build/

# ── Virtual Environment ──────────────────────────────────────────
.venv/
venv/
ENV/

# ── UV ───────────────────────────────────────────────────────────
# uv.lock is committed for reproducibility (do NOT gitignore)

# ── IDE ──────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
*.code-workspace

# ── Runtime Data (generated at runtime, never committed) ─────────
runtime_data/
!runtime_data/.gitkeep

# ── Configuration (secrets / local overrides) ────────────────────
config.json
.env
AGENTS.local.md

# ── OS ───────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Testing ──────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# ── Gemini / AI Agent ────────────────────────────────────────────
.gemini/
