# Striker environment variables — copy to .env and override as needed.
# These override config.json values (env has highest priority).

# Serial / MAVLink
# STRIKER_SERIAL_PORT=/dev/serial0
# STRIKER_SERIAL_BAUD=921600
# STRIKER_TRANSPORT=serial
# STRIKER_MAVLINK_URL=

# Safety thresholds
# STRIKER_BATTERY_MIN_V=11.1
# STRIKER_STALL_SPEED_MPS=10.0
# STRIKER_HEARTBEAT_TIMEOUT_S=3.0
# STRIKER_SAFETY_CHECK_INTERVAL_S=1.0

# Mission behaviour
# STRIKER_FIELD=sitl_default
# STRIKER_DRY_RUN=false

# Release config
# STRIKER_RELEASE_METHOD=mavlink
# STRIKER_RELEASE_CHANNEL=6
# STRIKER_RELEASE_PWM_OPEN=2000
# STRIKER_RELEASE_PWM_CLOSE=1000

# Vision config
# STRIKER_VISION_RECEIVER_TYPE=tcp
# STRIKER_VISION_HOST=0.0.0.0
# STRIKER_VISION_PORT=9876

# Flight recorder
# STRIKER_RECORDER_OUTPUT_PATH=flight_log.csv
# STRIKER_RECORDER_SAMPLE_RATE_HZ=1.0

# Logging
# STRIKER_LOG_LEVEL=INFO

# Platform override (rpi5, orin, sitl, unknown)
# STRIKER_PLATFORM=sitl
