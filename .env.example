# ── Striker 环境变量 ──────────────────────────────────────────────
# 所有环境变量以 STRIKER_ 为前缀，覆盖 config.json 中的同名配置。
# 优先级: 环境变量 > config.json > 代码默认值

# 串口配置
STRIKER_SERIAL_PORT=/dev/serial0
STRIKER_SERIAL_BAUD=921600

# 飞行参数
STRIKER_LOITER_RADIUS_M=80.0
STRIKER_LOITER_TIMEOUT_S=60.0
STRIKER_MAX_SCAN_CYCLES=3

# 场地配置
STRIKER_FIELD=sitl_default

# 安全开关
STRIKER_DRY_RUN=false
STRIKER_FORCED_STRIKE_ENABLED=true

# 日志级别
STRIKER_LOG_LEVEL=INFO
